# ===========================================
# AI Helpdesk - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# LLM Configuration
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus-latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# Database (default: SQLite)
DATABASE_URL=sqlite:///local_test.db

# Redis (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
WEBSOCKET_PORT=8765
LOG_LEVEL=INFO

# Feishu Bot Integration
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_BOT_WEBHOOK_URL=

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-string

# WeChat Bot (coming soon)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=
